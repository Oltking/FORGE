# --- Supabase (required to run the app) ---
# Create a free project at https://supabase.com, then copy these from
# Project Settings -> API. Save this file as .env.local and fill the values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anchoring backend (optional) ---
# Leave Hacash vars unset to use the local anchor (cryptographically real,
# off-chain). Set all three to inscribe Merkle roots onto Hacash mainnet.
# ANCHOR_BACKEND=local            # force local even if Hacash is configured
# HACASH_NODE_URL=http://127.0.0.1:8083
# HACASH_INSCRIBE_PRIVATE_KEY=
# HACASH_GENESIS_DIAMOND=WTHXMK
# HACASH_FEE=0.0001
# HACASH_INSCRIBE_PATH=create/diamond/inscription
# HACASH_INSCRIPTION_PREFIX=forge:

# --- System ---
# Protects POST /api/anchor in production (sent as x-anchor-secret).
# ANCHOR_CRON_SECRET=
